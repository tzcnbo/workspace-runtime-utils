{
  "name": "@workspace/api-server",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "node ../../scripts/ensure-dev-deps.mjs && tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:bundle": "node ./build.mjs",
    "build": "pnpm run typecheck && pnpm run build:bundle",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "openai": "^6.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "esbuild": "^0.27.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
