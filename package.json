{
  "name": "workspace",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/write-static-portal.mjs && pnpm --filter @workspace/api-server run build",
    "start": "node scripts/start-production.mjs",
    "dev": "pnpm --parallel --filter @workspace/api-server --filter @workspace/api-portal run dev",
    "portal:dev": "PORT=24927 BASE_PATH=/ API_TARGET=http://localhost:8080 pnpm --filter @workspace/api-portal run dev"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.26.1"
}
